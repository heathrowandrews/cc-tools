# Smart name: use project dir if meaningful, else short TTY label
smart_name() {
    local cwd="$1" tty="$2"
    local proj
    proj=$(basename "$cwd")
    # If cwd is home dir, use TTY-based label instead
    if [[ "$proj" == "$(whoami)" || "$proj" == "~" || -z "$proj" || "$proj" == "unknown" ]]; then
        # /dev/ttys009 → "term-9", /dev/ttys013 → "term-13"
        local tty_num="${tty##*/dev/ttys}"
        tty_num="${tty_num##*0}"  # strip leading zeros
        tty_num="${tty_num:-0}"
        printf 'term-%s' "$tty_num"
    else
        printf '%s' "$proj"
    fi
}

