}

# Look up cwd for a tty from hub json files (newest match)
get_cwd() {
    local tty="$1"
    local f="" content="" best_cwd="" best_ts=0

    for f in "$HUB_DIR"/*.json; do
        [[ -f "$f" ]] || continue
        content=$(read_stable_file "$f") || continue

        # Check if this file matches our tty
        local file_tty
        file_tty=$(printf '%s\n' "$content" | awk -F'"' '/"tty"/{print $4}' 2>/dev/null || true)
        [[ "$file_tty" == "$tty" ]] || continue

        local file_ts
        file_ts=$(printf '%s\n' "$content" | awk -F': *' '/"ts"/{gsub(/[^0-9]/,"",$2); print $2}' 2>/dev/null || true)
        file_ts="${file_ts:-0}"

        if (( file_ts > best_ts )); then
            best_ts=$file_ts
            best_cwd=$(printf '%s\n' "$content" | awk -F'"' '/"cwd"/{print $4}' 2>/dev/null || true)
        fi
    done
    printf '%s\n' "${best_cwd:-unknown}"
}

# ─── Get screen area (respects dock + menu bar) ─────────────────────────────
get_screen() {
    local output=""
    output=$(osascript 2>/dev/null <<'AS'
use framework "AppKit"
set s to current application's NSScreen's mainScreen()
set f to s's frame()
set v to s's visibleFrame()
set vx to item 1 of item 1 of v as integer
set vy to item 2 of item 1 of v as integer
set vw to item 1 of item 2 of v as integer
set vh to item 2 of item 2 of v as integer
set sh to item 2 of item 2 of f as integer
return (vx as text) & " " & ((sh - vy - vh) as text) & " " & (vw as text) & " " & (vh as text)
AS
) || output=""
    [[ -n "$output" ]] || return 1
    printf '%s\n' "$output"
}

# ─── Find Claude Code windows: "id|tty" sorted by id ────────────────────────
# Returns "id|tty|type" — type is "hub" or "claude"
find_windows() {
    local output=""
    output=$(osascript 2>/dev/null <<'AS'
set output to ""
try
    tell application "Terminal"
        repeat with w in windows
            set wName to name of w
            if wName contains "cc-hub" or wName contains "CC-HUB" then
                try
                    set output to output & (id of w as text) & "|" & tty of tab 1 of w & "|hub" & linefeed
                end try
            else if wName contains "claude" or wName contains "Claude" then
                try
                    set output to output & (id of w as text) & "|" & tty of tab 1 of w & "|claude" & linefeed
                end try
            end if
        end repeat
    end tell
end try
return output
AS
) || output=""

    [[ -n "$output" ]] || return 0
    printf '%s\n' "$output" | awk 'NF' | sort -t'|' -k1,1n
    return 0
}

# ─── Look up status for a tty from hub json files ───────────────────────────
get_status() {
    local tty="$1"
    local f="" content="" status=""
    local best_status="" best_ts=0

    for f in "$HUB_DIR"/*.json; do
        [[ -f "$f" ]] || continue

        content=$(read_stable_file "$f") || continue
        status=$(printf '%s\n' "$content" | status_from_json "$tty" || true)
        if [[ -n "$status" ]] && known_status "$status"; then
            # Extract timestamp and keep the newest match for this TTY
            local file_ts
            file_ts=$(printf '%s\n' "$content" | awk -F': *' '/"ts"/{gsub(/[^0-9]/,"",$2); print $2}' 2>/dev/null || true)
            file_ts="${file_ts:-0}"
            if (( file_ts > best_ts )); then
                best_ts=$file_ts
                best_status="$status"
            fi
        fi
    done
    printf '%s\n' "${best_status:-idle}"
    return 0
}

# Look up newest timestamp for a tty
get_status_ts() {
    local tty="$1"
    local f="" content="" best_ts=0

    for f in "$HUB_DIR"/*.json; do
        [[ -f "$f" ]] || continue
        content=$(read_stable_file "$f") || continue
        local file_tty
        file_tty=$(printf '%s\n' "$content" | awk -F'"' '/"tty"/{print $4}' 2>/dev/null || true)
        [[ "$file_tty" == "$tty" ]] || continue
        local file_ts
        file_ts=$(printf '%s\n' "$content" | awk -F': *' '/"ts"/{gsub(/[^0-9]/,"",$2); print $2}' 2>/dev/null || true)
        file_ts="${file_ts:-0}"
        (( file_ts > best_ts )) && best_ts=$file_ts
    done
    printf '%s\n' "$best_ts"
}

# ─── Grid math: how to divide N windows into rows/cols ───────────────────────
# Returns "cols rows" — always fills the screen completely.
grid_for() {
    local n=$1
    case "$n" in
        1) echo "1 1" ;; 2) echo "2 1" ;; 3) echo "2 2" ;;
        4) echo "2 2" ;; 5) echo "3 2" ;; 6) echo "3 2" ;;
        7) echo "4 2" ;; 8) echo "4 2" ;; 9) echo "3 3" ;;
        *) echo "4 3" ;;
    esac
}

# ─── Main action: tile + color all windows ───────────────────────────────────
# Focus-aware layout: focused window breathes larger, others shrink to fit

FOCUS_BOOST_W=0    # disabled — equal grid
FOCUS_BOOST_H=0    # disabled — equal grid
FOCUS_MAX_W=50     # unused when boost is 0

# Detect which Terminal window is frontmost
get_focused_id() {
    osascript -e 'try
        tell application "Terminal" to get id of front window
    end try' 2>/dev/null || echo ""
}

# Calculate target bounds for all windows, with focus boost for focused_id
# Outputs: "wid x y x2 y2" per line
calc_layout() {
    local focused_id="$1" ox="$2" oy="$3" sw="$4" sh="$5"
    shift 5
    local wins=("$@")
    local n=${#wins[@]}
    (( n == 0 )) && return 0

    local cols rows
    read -r cols rows <<< "$(grid_for "$n")"

    local placed=0
    for (( row=0; row<rows && placed<n; row++ )); do
        local remaining=$(( n - placed ))
        local rows_left=$(( rows - row ))
        local in_row=$(( remaining / rows_left ))
        (( remaining % rows_left > 0 )) && (( in_row++ ))

        # Check if focused window is in this row
        local focus_in_row=0 focus_col=-1
        for (( c=0; c<in_row && (placed+c)<n; c++ )); do
            local check_wid="${wins[$((placed+c))]%%|*}"
            if [[ "$check_wid" == "$focused_id" ]]; then
                focus_in_row=1
                focus_col=$c
                break
            fi
        done

        # Check if focused window is in this row-block for height
        local focus_in_row_block=0
        for (( c=0; c<in_row && (placed+c)<n; c++ )); do
            local check_wid="${wins[$((placed+c))]%%|*}"
            [[ "$check_wid" == "$focused_id" ]] && focus_in_row_block=1
        done

        # Row heights: give focused row a boost
        local base_h=$(( sh / rows ))
        local row_y row_h
        if (( focus_in_row_block && rows > 1 )); then
            local boost_h=$(( base_h * FOCUS_BOOST_H / 100 ))
            local shrink_h=$(( boost_h / (rows - 1) ))
            # Are we in the focused row?
            row_h=$(( base_h + boost_h ))
            # Calculate y based on which row and adjustments
            row_y=$oy
            for (( pr=0; pr<row; pr++ )); do
                # Check if previous row had focus
                local prev_had_focus=0
                local prev_start=0 prev_in_row=0
                local pp=0
                for (( pr2=0; pr2<pr; pr2++ )); do
                    local pr_rem=$(( n - pp ))
                    local pr_rl=$(( rows - pr2 ))
                    local pr_ir=$(( pr_rem / pr_rl ))
                    (( pr_rem % pr_rl > 0 )) && (( pr_ir++ ))
                    pp=$(( pp + pr_ir ))
                done
                prev_start=$pp
                local pr_rem2=$(( n - prev_start ))
                local pr_rl2=$(( rows - pr ))
                prev_in_row=$(( pr_rem2 / pr_rl2 ))
                (( pr_rem2 % pr_rl2 > 0 )) && (( prev_in_row++ ))
                for (( pc=0; pc<prev_in_row; pc++ )); do
                    local pw="${wins[$((prev_start+pc))]%%|*}"
                    [[ "$pw" == "$focused_id" ]] && prev_had_focus=1
                done
                if (( prev_had_focus )); then
                    row_y=$(( row_y + base_h + boost_h ))
                else
                    row_y=$(( row_y + base_h - shrink_h ))
                fi
            done
        else
            row_h=$base_h
            row_y=$(( oy + row * base_h ))
        fi
        # Last row snaps to bottom
        (( row == rows - 1 )) && row_h=$(( oy + sh - row_y ))

        # Column widths: focused gets boost, others shrink
        local widths=()
        if (( focus_in_row && in_row > 1 )); then
            local base_w=$(( sw / in_row ))
            local boost_w=$(( base_w * FOCUS_BOOST_W / 100 ))
            local max_w=$(( sw * FOCUS_MAX_W / 100 ))
            local focus_w=$(( base_w + boost_w ))
            (( focus_w > max_w )) && focus_w=$max_w
            local leftover=$(( sw - focus_w ))
            local other_w=$(( leftover / (in_row - 1) ))
            for (( c=0; c<in_row; c++ )); do
                if (( c == focus_col )); then
                    widths+=("$focus_w")
                else
                    widths+=("$other_w")
                fi
            done
        else
            for (( c=0; c<in_row; c++ )); do
                widths+=("$(( sw / in_row ))")
            done
        fi

        local cum_x=$ox
        for (( col=0; col<in_row && placed<n; col++ )); do
            local wid="${wins[$placed]%%|*}"
            local x=$cum_x
            local y=$row_y
            local w="${widths[$col]}"
            local x2=$(( x + w ))
            local y2=$(( y + row_h ))
            # Last col/row snap to edge
            (( col == in_row - 1 )) && x2=$(( ox + sw ))
            (( row == rows - 1 )) && y2=$(( oy + sh ))
            cum_x=$x2

            echo "$wid $x $y $x2 $y2"
            (( placed++ ))
        done
    done
}

# Full snap: calculate layout with focus boost, apply positions + colors
do_snap() {
    local full_style="${1:-false}"
    local screen
    screen=$(get_screen) || return 1
    local ox oy sw sh
    [[ -n "$screen" ]] || return 1
    if ! read -r ox oy sw sh <<< "$screen"; then
        return 1
    fi

    # Get Claude windows only
    local claude_wins=()
    while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        local wtype="${line##*|}"
        [[ "$wtype" == "hub" ]] && continue
        claude_wins+=("$line")
    done < <(find_windows)

    local n=${#claude_wins[@]}
    (( n == 0 )) && return 0

    # Get focused window for layout boost
    local focused_id
    focused_id=$(get_focused_id)

    # Calculate target layout
    local layout
    layout=$(calc_layout "$focused_id" "$ox" "$oy" "$sw" "$sh" "${claude_wins[@]}")

    # Apply positions + colors + titles
    local as="tell application \"Terminal\""$'\n'
    local idx=0
    while IFS=' ' read -r wid tx ty tx2 ty2 || [[ -n "$wid" ]]; do
        local entry="${claude_wins[$idx]}"
        local rest="${entry#*|}"
        local wtty="${rest%%|*}"

        local status
        status=$(get_status "$wtty" || true)
        known_status "$status" || status="idle"

        # Auto-dim: if done/idle for too long, treat as stale
        local sts_ts age="" diff_s=0
        sts_ts=$(get_status_ts "$wtty")
        local now_ts
        now_ts=$(date +%s)
        if [[ -n "$sts_ts" && "$sts_ts" != "0" ]]; then
            diff_s=$(( now_ts - sts_ts ))
            if (( diff_s < 60 )); then age="${diff_s}s"
            elif (( diff_s < 3600 )); then age="$(( diff_s / 60 ))m"
            else age="$(( diff_s / 3600 ))h"
            fi
        fi
        if [[ "$status" == "done" || "$status" == "idle" ]] && (( diff_s > STALE_AFTER )); then
            status="stale"
        fi

        # Focus brightening: click a dim window and it lights up to reading mode
        local visual_status="$status"
        if [[ "$wid" == "$focused_id" ]] && [[ "$status" == "stale" || "$status" == "ended" || "$status" == "done" || "$status" == "idle" ]]; then
            visual_status="reading"
        fi

        local bg fg bold curs icon cwd name title
        bg=$(bg_color "$visual_status")
        fg=$(fg_color "$visual_status")
        bold=$(bold_color "$visual_status")
        curs=$(cursor_color "$visual_status")
        icon=$(status_icon "$status")  # icon shows real status, not visual
        cwd=$(get_cwd "$wtty")
        name=$(smart_name "$cwd" "$wtty")
        title="${icon} ${name} ${status}${age:+ ${age}}"

        as+="  try"$'\n'
        as+="    set bounds of window id $wid to {$tx, $ty, $tx2, $ty2}"$'\n'
        as+="    set t to tab 1 of window id $wid"$'\n'
        as+="    set background color of t to {$bg}"$'\n'
        as+="    set normal text color of t to {$fg}"$'\n'
        as+="    set bold text color of t to {$bold}"$'\n'
        as+="    set cursor color of t to {$curs}"$'\n'
        as+="    set custom title of t to \"$title\""$'\n'
        if [[ "$full_style" == "true" ]]; then
            as+="    set font name of t to \"Menlo-Regular\""$'\n'
            as+="    set font size of t to 12"$'\n'
            as+="$(ansi_block "$visual_status")"$'\n'
        fi
        as+="  end try"$'\n'
        (( idx++ ))
    done <<< "$layout"

    as+="end tell"
    osascript -e "$as" 2>/dev/null || true
    return 0
}

# ─── Daemon: watch for changes, style continuously ──────────────────────────
run_daemon() {
    echo $$ > "$PID_FILE"
    trap 'cleanup_pid_file; exit 0' INT TERM
    trap 'cleanup_pid_file' EXIT

    echo "cc-snap running (pid $$)"

    local last_ids=""
    local tick=0
    local clean_tick=0

    while true; do
        # Auto-clean stale files every ~60s (30 cycles × 2s)
        clean_tick=$(( clean_tick + 1 ))
        if (( clean_tick >= 30 )); then
            clean_tick=0
            for sf in "$HUB_DIR"/*.json; do
                [[ -f "$sf" ]] || continue
                local sf_ts
                sf_ts=$(awk -F': *' '/"ts"/{gsub(/[^0-9]/,"",$2); print $2}' "$sf" 2>/dev/null || true)
                sf_ts="${sf_ts:-0}"
                local sf_status
                sf_status=$(awk -F'"' '/"status"/{print $4}' "$sf" 2>/dev/null || true)
                if [[ "$sf_status" == "ended" ]] && (( sf_ts > 0 && $(date +%s) - sf_ts > 300 )); then
                    rm -f "$sf"
                fi
            done
        fi

        local ids
        ids=$(find_windows 2>/dev/null | cut -d'|' -f1 | tr '\n' ',') || ids=""

        if [[ -n "$ids" ]]; then
            if [[ "$ids" != "$last_ids" ]]; then
                # Windows changed — settle then full style
                sleep 1
                local ids2
                ids2=$(find_windows 2>/dev/null | cut -d'|' -f1 | tr '\n' ',') || ids2=""
                if [[ "$ids2" == "$ids" ]]; then
                    echo "[$(date +%H:%M:%S)] reflow"
                    do_snap true || true
                    last_ids="$ids"
                    tick=0
                fi
            else
                # Same windows — snap every tick (focus-aware layout + colors)
                tick=$(( tick + 1 ))
                if [[ $tick -ge 1 ]]; then
                    tick=0
                    do_snap
                fi
            fi
        else
            last_ids=""
            last_statuses=""
            tick=0
        fi

        sleep 2
    done
}

# ─── CLI ─────────────────────────────────────────────────────────────────────
case "${1:-}" in
    --watch|-w)
        run_daemon
        ;;
    --bg)
        stop_watchers || true
        sleep 0.5
        rm -f "$PID_FILE"
        nohup "$0" --watch > "$LOG_FILE" 2>&1 &
        disown || true
        echo "cc-snap started (pid $!)"
        ;;
    --stop)
        if stop_watchers; then
            echo "cc-snap stopped"
        else
            echo "not running"
        fi
        ;;
    --status)
        if pid=$(read_pid_file 2>/dev/null) && pid_is_watcher "$pid" && kill -0 "$pid" 2>/dev/null; then
            echo "running (pid $pid)"
        else
            rm -f "$PID_FILE"
            echo "not running"
        fi
        ;;
    --help|-h)
        cat <<'EOF'
cc-snap — Claude Code window manager

  cc-snap           Tile + color once
  cc-snap --bg      Run in background
  cc-snap --stop    Stop background daemon
  cc-snap --status  Check if running
  cc-snap --watch   Run in foreground (for debugging)
EOF
        ;;
    *)
        do_snap true && echo "done" || echo "no windows found"
        ;;
esac
