#!/usr/bin/env bash
# cc-snap — The one and only Claude Code window manager
# Tiles windows edge-to-edge, colors by status, leaves names alone.
# Simple. No fighting. One process.

set -uo pipefail

HUB_DIR="/tmp/cc-hub"
PID_FILE="/tmp/cc-snap.pid"
LOG_FILE="/tmp/cc-snap.log"

known_status() {
    case "${1:-}" in
        idle|working|approval|done|stale|ended) return 0 ;;
        *) return 1 ;;
    esac
}

# Seconds before "done" auto-dims to "stale"
STALE_AFTER=180  # 3 minutes

read_pid_file() {
    local pid
    [[ -f "$PID_FILE" ]] || return 1
    pid=$(tr -cd '0-9' < "$PID_FILE" 2>/dev/null || true)
    [[ -n "$pid" ]] || return 1
    printf '%s\n' "$pid"
}

pid_is_watcher() {
    local pid="${1:-}"
    local cmd=""

    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    cmd=$(ps -p "$pid" -o command= 2>/dev/null || true)
    [[ -n "$cmd" ]] || return 1
    [[ "$cmd" == *cc-snap* ]] || return 1
    [[ "$cmd" == *" --watch"* ]] || return 1
}

cleanup_pid_file() {
    local pid=""
    pid=$(read_pid_file 2>/dev/null || true)
    if [[ -n "$pid" && "$pid" == "$$" ]]; then
        rm -f "$PID_FILE"
    fi
}

list_watch_pids() {
    {
        read_pid_file 2>/dev/null || true
        pgrep -f 'cc-snap.*--watch' 2>/dev/null || true
    } | awk 'NF && !seen[$0]++ { print }' | while IFS= read -r pid; do
        pid_is_watcher "$pid" || continue
        printf '%s\n' "$pid"
    done
    return 0
}

stop_watchers() {
    local pid=""
    local found=0
    local pass=0

    while IFS= read -r pid; do
        [[ -n "$pid" ]] || continue
        found=1
        kill "$pid" 2>/dev/null || true
    done < <(list_watch_pids)

    if (( found == 0 )); then
        rm -f "$PID_FILE"
        return 1
    fi

    for (( pass=0; pass<5; pass++ )); do
        local remaining=""
        remaining=$(list_watch_pids || true)
        [[ -z "$remaining" ]] && break
        sleep 0.2
    done

    while IFS= read -r pid; do
        [[ -n "$pid" ]] || continue
        kill -9 "$pid" 2>/dev/null || true
    done < <(list_watch_pids)

    rm -f "$PID_FILE"
    return 0
}

read_stable_file() {
    local file="$1"
    local before="" after="" content=""

    [[ -f "$file" ]] || return 1
    before=$(wc -c < "$file" 2>/dev/null || true)
    [[ -n "$before" ]] || return 1

    content=$(cat "$file" 2>/dev/null || true)
    after=$(wc -c < "$file" 2>/dev/null || true)
    [[ -n "$after" ]] || return 1

    [[ "$before" == "$after" ]] || return 1
    [[ -n "$content" ]] || return 1
    printf '%s' "$content"
}

status_from_json() {
    local tty="$1"

    awk -v tty_target="$tty" '
        {
            text = text $0 "\n"
        }
        END {
            if (text !~ /^[[:space:]]*{/) exit 1
            if (text !~ /}[[:space:]]*$/) exit 1

            tty_pat = "\"tty\"[[:space:]]*:[[:space:]]*\""
            status_pat = "\"status\"[[:space:]]*:[[:space:]]*\""

            if (!match(text, tty_pat)) exit 1
            rest = substr(text, RSTART + RLENGTH)
            if (!match(rest, /"/)) exit 1
            file_tty = substr(rest, 1, RSTART - 1)

            if (!match(text, status_pat)) exit 1
            rest = substr(text, RSTART + RLENGTH)
            if (!match(rest, /"/)) exit 1
            file_status = substr(rest, 1, RSTART - 1)

            if (file_tty != tty_target) exit 1
            if (file_status !~ /^(idle|working|approval|done|ended)$/) exit 1

            print file_status
        }
    ' 2>/dev/null
}

# ─── Status colors (Terminal.app RGB 0-65535) ────────────────────────────────
# ─── Cyberpunk palette v2 ────────────────────────────────────────────────────
# Design principle: you should be able to glance at 6 windows and instantly
# know which ones need you, which are alive, and which are sleeping.
#
# Statuses (from Claude Code hooks):
#   idle     — session started, waiting for first prompt
#   working  — Claude is thinking or running tools
#   approval — Claude needs you to approve a tool call (LOOK AT ME)
#   done     — Claude finished its turn, your move
#   stale    — done for >3 min, cooling off (auto-set by cc-snap)
#   ended    — session closed
#   reading  — you clicked a dim window, brighten up so you can read it
#
bg_color() {
    case "$1" in
        working)  echo "800,2500,1000" ;;      # faint green glow — alive
        approval) echo "3000,1800,400" ;;      # warm amber glow — HEY LOOK
        done)     echo "1200,1200,1500" ;;     # cool dark gray — finished
        reading)  echo "2200,2200,2800" ;;     # warm charcoal — readable without glare
        stale)    echo "600,600,700" ;;        # near-black — asleep
        ended)    echo "400,400,400" ;;        # void — unplugged
        *)        echo "600,800,600" ;;        # deep dark — idle
    esac
}

fg_color() {
    case "$1" in
        working)  echo "0,65535,0" ;;          # BLAZING neon green — Matrix rain
        approval) echo "65535,45000,0" ;;      # hot amber — NEEDS YOU
        done)     echo "18000,24000,18000" ;;  # muted green — readable but receded
        reading)  echo "38000,42000,38000" ;;  # soft white-green — comfortable reading
        stale)    echo "8000,10000,8000" ;;    # ghostly — barely there
        ended)    echo "3000,3000,3000" ;;     # near-invisible — dead
        *)        echo "5000,8000,5000" ;;     # dim green — sleeping
    esac
}

